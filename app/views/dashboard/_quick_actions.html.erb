<div class="flex flex-wrap gap-3">
  <%= link_to new_transaction_path,
      class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Add Transaction
  <% end %>

  <%= link_to new_transfer_path,
      class: "inline-flex items-center gap-2 rounded-md bg-white px-4 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    New Transfer
  <% end %>

  <%= link_to new_csv_import_path,
      class: "inline-flex items-center gap-2 rounded-md bg-white px-4 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Import CSV
  <% end %>

  <%= link_to transactions_path,
      class: "inline-flex items-center gap-2 rounded-md bg-white px-4 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" do %>
    View All Transactions
  <% end %>
</div>
