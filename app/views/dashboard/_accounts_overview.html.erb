<div class="bg-white rounded-lg border border-slate-200 p-4 sm:p-6">
  <h2 class="text-sm font-medium text-slate-500 uppercase tracking-wide">Accounts</h2>

  <% if @accounts.any? %>
    <ul class="mt-3 divide-y divide-slate-100">
      <% @accounts.each do |account| %>
        <li class="flex items-center justify-between py-2.5">
          <div class="flex items-center gap-3">
            <%= account_type_badge(account.account_type) %>
            <%= link_to account.name, account, class: "text-sm font-medium text-slate-900 hover:text-indigo-600" %>
          </div>
          <span class="text-sm font-semibold tabular-nums <%= account.balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
            <%= format_currency(account.balance) %>
          </span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-3 text-sm text-slate-500">No accounts yet.</p>
  <% end %>

  <div class="mt-3">
    <%= link_to "View all accounts →", accounts_path,
        class: "text-sm font-medium text-indigo-600 hover:text-indigo-700",
        aria: { label: "View all accounts" } %>
  </div>
</div>
