<div class="bg-white rounded-lg border border-slate-200">
  <div class="p-4 sm:p-6 pb-0 sm:pb-0">
    <h2 class="text-sm font-medium text-slate-500 uppercase tracking-wide">Recent Transactions</h2>
  </div>

  <% if @recent_transactions.any? %>
    <%# Desktop table %>
    <div class="hidden sm:block mt-3">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Date</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Description</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Kind</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Category</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Account</th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @recent_transactions.each do |transaction| %>
            <tr>
              <td class="px-4 py-3 text-sm text-slate-500 whitespace-nowrap">
                <%= format_transaction_date(transaction.transaction_date) %>
              </td>
              <td class="px-4 py-3">
                <span class="text-sm font-medium text-slate-900"><%= transaction.note.presence || "—" %></span>
              </td>
              <td class="px-4 py-3"><%= transaction_kind_badge(transaction) %></td>
              <td class="px-4 py-3 text-sm text-slate-500"><%= transaction.category&.name || "—" %></td>
              <td class="px-4 py-3 text-sm text-slate-500"><%= transaction.account.name %></td>
              <td class="px-4 py-3 text-sm font-medium tabular-nums text-right">
                <%= format_transaction_amount(transaction) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Mobile cards %>
    <div class="sm:hidden mt-3 divide-y divide-slate-100">
      <% @recent_transactions.each do |transaction| %>
        <div class="px-4 py-3">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-slate-900 truncate"><%= transaction.note.presence || transaction.category&.name || transaction.kind.humanize %></span>
            <span class="text-sm font-semibold tabular-nums ml-2"><%= format_transaction_amount(transaction) %></span>
          </div>
          <div class="mt-1 flex items-center gap-1.5 text-xs text-slate-500">
            <%= transaction_kind_badge(transaction) %>
            <% if transaction.category.present? %>
              <span><%= transaction.category.name %></span>
              <span>&middot;</span>
            <% end %>
            <span><%= transaction.account.name %></span>
          </div>
          <p class="mt-1 text-xs text-slate-400"><%= format_transaction_date(transaction.transaction_date) %></p>
        </div>
      <% end %>
    </div>

    <div class="p-4 sm:p-6 pt-3 sm:pt-3">
      <%= link_to "View all transactions →", transactions_path,
          class: "text-sm font-medium text-indigo-600 hover:text-indigo-700",
          aria: { label: "View all transactions" } %>
    </div>
  <% else %>
    <div class="p-4 sm:p-6 pt-3 sm:pt-3 text-center py-8">
      <p class="text-sm text-slate-500">No transactions yet.</p>
      <div class="mt-4 flex items-center justify-center gap-3">
        <%= link_to new_transaction_path,
            class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Add Transaction
        <% end %>
      </div>
    </div>
  <% end %>
</div>
