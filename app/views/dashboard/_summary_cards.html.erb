<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
  <div class="bg-white rounded-lg border border-slate-200 p-4 shadow-sm">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Net Balance</p>
    </div>
    <p class="mt-1 text-2xl font-semibold tabular-nums <%= @total_balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
      <%= format_currency(@total_balance) %>
    </p>
  </div>

  <div class="bg-white rounded-lg border border-slate-200 p-4 shadow-sm">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Income This Month</p>
    </div>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-emerald-600">
      +<%= format_currency(@month_income) %>
    </p>
  </div>

  <div class="bg-white rounded-lg border border-slate-200 p-4 shadow-sm">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Expenses This Month</p>
    </div>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-rose-600">
      -<%= format_currency(@month_expenses) %>
    </p>
  </div>

  <div class="bg-white rounded-lg border border-slate-200 p-4 shadow-sm">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Net This Month</p>
    </div>
    <% net_color = if @month_net.positive?
                     "text-emerald-600"
                   elsif @month_net.negative?
                     "text-rose-600"
                   else
                     "text-slate-400"
                   end %>
    <p class="mt-1 text-2xl font-semibold tabular-nums <%= net_color %>">
      <%= @month_net.positive? ? "+" : "" %><%= format_currency(@month_net) %>
    </p>
  </div>
</div>
