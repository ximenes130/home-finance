<div class="text-center py-16">
  <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <h2 class="mt-4 text-lg font-semibold text-slate-900">Welcome to Home Finance!</h2>
  <p class="mt-2 text-sm text-slate-500">Get started by creating your first account to begin tracking your household finances.</p>
  <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
    <%= link_to new_account_path,
        class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-5 py-3 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Create Your First Account
    <% end %>
    <%= link_to "Add Categories", categories_path,
        class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %>
  </div>
</div>
