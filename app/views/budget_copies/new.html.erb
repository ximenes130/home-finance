<%= render "shared/page_header", title: "Copy Budgets" %>

<p class="mb-6 text-sm text-slate-500">
  Copy all budgets from a source month into <strong><%= budget_month_label(@target_year, @target_month) %></strong>.
  Any budget whose category already has a budget in the target month will be skipped.
</p>

<%= form_with scope: :budget_copy, url: budget_copy_path, method: :post, class: "space-y-6 max-w-lg" do |f| %>
  <%= f.hidden_field :target_year, value: @target_year %>
  <%= f.hidden_field :target_month, value: @target_month %>

  <div class="flex gap-4">
    <div class="flex-1">
      <%= f.label :source_month, "From Month", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :source_month,
          options_for_select((1..12).map { |m| [Date::MONTHNAMES[m], m] }, @source_month),
          {},
          class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="flex-1">
      <%= f.label :source_year, "From Year", class: "block text-sm font-medium text-slate-700" %>
      <%= f.number_field :source_year,
          value: @source_year,
          class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          min: 2000, step: 1 %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit "Copy Budgets",
        class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", budgets_path(year: @target_year, month: @target_month),
        class: "text-sm font-medium text-slate-600 hover:text-slate-800" %>
  </div>
<% end %>
