<div class="flex items-center justify-between mb-6">
  <h1 class="text-lg font-semibold text-slate-900">Transactions</h1>
  <div class="flex items-center gap-2">
    <%= link_to new_csv_export_path,
        class: "inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12M12 16.5V3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Export
    <% end %>
    <%= link_to new_transfer_path,
        class: "inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Transfer
    <% end %>
    <%= link_to new_transaction_path,
        class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      New Transaction
    <% end %>
  </div>
</div>

<%= turbo_frame_tag "transactions" do %>
  <%= render "filters" %>

  <% if @transactions.any? %>
    <p class="mt-4 mb-2 text-sm text-slate-500"><%= pluralize(@transactions.size, "transaction") %> found</p>

    <%# Desktop table %>
    <div class="hidden sm:block bg-white rounded-lg border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Date</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Description</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Kind</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Category</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Account</th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Amount</th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @transactions.each do |transaction| %>
            <%= render "transaction", transaction: transaction %>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Mobile cards %>
    <div class="sm:hidden bg-white rounded-lg border border-slate-200 divide-y divide-slate-100">
      <% @transactions.each do |transaction| %>
        <div class="p-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-slate-900 truncate"><%= transaction.note.presence || transaction.category&.name || transaction.kind.humanize %></span>
            <span class="text-sm font-semibold tabular-nums ml-2"><%= format_transaction_amount(transaction) %></span>
          </div>
          <div class="mt-1 flex items-center gap-1.5 text-xs text-slate-500">
            <%= transaction_kind_badge(transaction) %>
            <% if transaction.category.present? %>
              <span><%= transaction.category.name %></span>
              <span>&middot;</span>
            <% end %>
            <span><%= transaction.account.name %></span>
            <% if transaction.transfer_pair_id.present? && (pair = transaction.transfer_pair) %>
              <span>&middot;</span>
              <span class="text-blue-500">&harr; <%= pair.account.name %></span>
            <% end %>
          </div>
          <div class="mt-1 flex items-center justify-between">
            <span class="text-xs text-slate-400"><%= format_transaction_date(transaction.transaction_date) %></span>
            <div class="flex items-center gap-2">
              <%= link_to "Edit", edit_transaction_path(transaction), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
              <%= button_to "Delete", transaction_path(transaction), method: :delete,
                  data: { turbo_confirm: transaction.transfer_pair_id.present? ? "Delete this transfer? Both sides will be removed. This cannot be undone." : "Delete this transaction? This cannot be undone." },
                  class: "text-sm text-rose-600 hover:text-rose-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <% if params[:account_id].present? || params[:category_id].present? || params[:kind].present? %>
        <h3 class="mt-2 text-sm font-semibold text-slate-900">No transactions match your filters</h3>
        <p class="mt-1 text-sm text-slate-500">Try adjusting your filters or clear them to see all transactions.</p>
        <div class="mt-6">
          <%= link_to "Clear filters", transactions_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %>
        </div>
      <% else %>
        <h3 class="mt-2 text-sm font-semibold text-slate-900">No transactions yet</h3>
        <p class="mt-1 text-sm text-slate-500">Record your first transaction to start tracking your finances.</p>
        <div class="mt-6 flex items-center justify-center gap-3">
          <%= link_to new_transaction_path,
              class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Add Transaction
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
