<%= render "csv_imports/step_indicator", step: 1 %>

<h1 class="text-lg font-semibold text-slate-900 mb-6">Import Transactions from CSV</h1>

<div class="bg-white rounded-lg border border-slate-200 p-4 sm:p-6">
  <%= form_with model: @csv_import, url: csv_imports_path, multipart: true, class: "space-y-5" do |f| %>
    <% if @csv_import.errors.any? %>
      <div class="rounded-md bg-rose-50 border border-rose-200 p-4" role="alert">
        <ul class="text-sm text-rose-800">
          <% @csv_import.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :account_id, "Account", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.collection_select :account_id, @accounts, :id, :name,
            { prompt: "Select an account" },
            class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 min-h-[44px]" %>
    </div>

    <div>
      <label for="csv_import_file" class="block text-sm font-medium text-slate-700 mb-1">CSV File</label>
      <input type="file" name="csv_import[file]" id="csv_import_file" accept=".csv"
             class="block w-full text-sm text-slate-700 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 min-h-[44px]" />
      <p class="mt-1 text-xs text-slate-500">Accepted format: .csv</p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Upload & Continue", class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 cursor-pointer min-h-[44px]" %>
      <%= link_to "Cancel", csv_imports_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
