<%= render "csv_imports/step_indicator", step: 0 %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-lg font-semibold text-slate-900">Import History</h1>
  <div class="flex items-center gap-2">
    <%= link_to new_csv_export_path, class: "inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12M12 16.5V3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Export
    <% end %>
    <%= link_to new_csv_import_path, class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    New Import
  <% end %>
  </div>
</div>

<% if @csv_imports.any? %>
  <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200 hidden sm:table">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Filename</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Account</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Status</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Imported</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Skipped</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @csv_imports.each do |csv_import| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 text-sm font-medium text-slate-900">
              <%= link_to csv_import.filename, csv_import_path(csv_import), class: "text-indigo-600 hover:text-indigo-700" %>
            </td>
            <td class="px-4 py-3 text-sm text-slate-700"><%= csv_import.account.name %></td>
            <td class="px-4 py-3"><%= import_status_badge(csv_import.status) %></td>
            <td class="px-4 py-3 text-sm tabular-nums text-right text-slate-700"><%= csv_import.imported_count %></td>
            <td class="px-4 py-3 text-sm tabular-nums text-right text-slate-700"><%= csv_import.skipped_count %></td>
            <td class="px-4 py-3 text-xs text-slate-500"><%= csv_import.created_at.strftime("%b %d, %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%# Mobile cards %>
    <div class="sm:hidden divide-y divide-slate-100">
      <% @csv_imports.each do |csv_import| %>
        <%= link_to csv_import_path(csv_import), class: "block p-4 hover:bg-slate-50" do %>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-slate-900"><%= csv_import.filename %></span>
            <%= import_status_badge(csv_import.status) %>
          </div>
          <div class="mt-1 flex items-center gap-3 text-xs text-slate-500">
            <span><%= csv_import.account.name %></span>
            <span>&middot;</span>
            <span><%= csv_import.imported_count %> imported, <%= csv_import.skipped_count %> skipped</span>
          </div>
          <div class="mt-1 text-xs text-slate-400"><%= csv_import.created_at.strftime("%b %d, %Y") %></div>
        <% end %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-slate-200 p-8 text-center">
    <p class="text-sm text-slate-500">No imports yet. Import your first CSV file to get started.</p>
    <div class="mt-4">
      <%= link_to new_csv_import_path, class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Import CSV File
      <% end %>
    </div>
  </div>
<% end %>
