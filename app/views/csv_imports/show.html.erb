<h1 class="text-lg font-semibold text-slate-900 mb-6">
  <% if @csv_import.completed? %>
    Import Complete ✓
  <% elsif @csv_import.failed? %>
    Import Failed ✗
  <% else %>
    Import Details
  <% end %>
</h1>

<div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Imported</p>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-emerald-600"><%= @csv_import.imported_count %></p>
  </div>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Skipped</p>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-slate-900"><%= @csv_import.skipped_count %></p>
  </div>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Rows</p>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-slate-900"><%= @csv_import.row_count %></p>
  </div>
</div>

<div class="bg-white rounded-lg border border-slate-200 p-4 sm:p-6 mb-6">
  <dl class="space-y-3 text-sm">
    <div class="flex justify-between">
      <dt class="text-slate-500">File</dt>
      <dd class="font-medium text-slate-900"><%= @csv_import.filename %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-slate-500">Account</dt>
      <dd class="font-medium text-slate-900"><%= @csv_import.account.name %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-slate-500">Status</dt>
      <dd><%= import_status_badge(@csv_import.status) %></dd>
    </div>
    <% if @csv_import.imported_at.present? %>
      <div class="flex justify-between">
        <dt class="text-slate-500">Imported at</dt>
        <dd class="font-medium text-slate-900"><%= @csv_import.imported_at.strftime("%b %d, %Y %H:%M") %></dd>
      </div>
    <% end %>
  </dl>
</div>

<% if @csv_import.failed? %>
  <div class="rounded-md bg-rose-50 border border-rose-200 p-4 mb-6">
    <p class="text-sm text-rose-800">An error occurred during import. No transactions were imported.</p>
  </div>
<% end %>

<div class="flex flex-wrap gap-3">
  <% if @csv_import.completed? %>
    <%= link_to transactions_path, class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 min-h-[44px]" do %>
      View Imported Transactions
    <% end %>
  <% end %>
  <%= link_to "Import Another File", new_csv_import_path, class: "inline-flex items-center gap-2 rounded-md bg-white px-4 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50 min-h-[44px]" %>
  <%= link_to "Back to Imports", csv_imports_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900 self-center" %>
</div>
