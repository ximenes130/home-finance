<%= form_with(model: budget, class: "space-y-6 max-w-lg") do |f| %>
  <div>
    <%= f.label :category_id, "Category", class: "block text-sm font-medium text-slate-700" %>
    <% if budget.persisted? %>
      <p class="mt-1 text-sm text-slate-900"><%= budget.category.name %></p>
      <p class="mt-1 text-xs text-slate-500">To budget a different category or month, create a new budget.</p>
    <% else %>
      <%= f.select :category_id,
          options_from_collection_for_select(Category.expense.order(:name), :id, :name, budget.category_id),
          { include_blank: "Select a category" },
          class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm #{budget.errors[:category_id].any? ? 'border-rose-300 text-rose-900 focus:border-rose-500 focus:ring-rose-500' : ''}" %>
    <% end %>
    <% if budget.errors[:category_id].any? %>
      <p class="mt-1 text-sm text-rose-600"><%= budget.errors.full_messages_for(:category_id).first %></p>
    <% end %>
  </div>

  <div class="flex gap-4">
    <div class="flex-1">
      <%= f.label :month, class: "block text-sm font-medium text-slate-700" %>
      <% if budget.persisted? %>
        <p class="mt-1 text-sm text-slate-900"><%= Date::MONTHNAMES[budget.month] %></p>
      <% else %>
        <%= f.select :month,
            options_for_select((1..12).map { |m| [Date::MONTHNAMES[m], m] }, budget.month),
            {},
            class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm #{budget.errors[:month].any? ? 'border-rose-300 text-rose-900 focus:border-rose-500 focus:ring-rose-500' : ''}" %>
      <% end %>
      <% if budget.errors[:month].any? %>
        <p class="mt-1 text-sm text-rose-600"><%= budget.errors.full_messages_for(:month).first %></p>
      <% end %>
    </div>

    <div class="flex-1">
      <%= f.label :year, class: "block text-sm font-medium text-slate-700" %>
      <% if budget.persisted? %>
        <p class="mt-1 text-sm text-slate-900"><%= budget.year %></p>
      <% else %>
        <%= f.number_field :year,
            class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm #{budget.errors[:year].any? ? 'border-rose-300 text-rose-900 focus:border-rose-500 focus:ring-rose-500' : ''}",
            min: 2000, step: 1 %>
      <% end %>
      <% if budget.errors[:year].any? %>
        <p class="mt-1 text-sm text-rose-600"><%= budget.errors.full_messages_for(:year).first %></p>
      <% end %>
    </div>
  </div>

  <div>
    <%= f.label :amount_limit, "Spending Limit", class: "block text-sm font-medium text-slate-700" %>
    <%= f.number_field :amount_limit,
        class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm #{budget.errors[:amount_limit].any? ? 'border-rose-300 text-rose-900 focus:border-rose-500 focus:ring-rose-500' : ''}",
        step: 0.01, min: 0.01, inputmode: "decimal", placeholder: "0.00" %>
    <% if budget.errors[:amount_limit].any? %>
      <p class="mt-1 text-sm text-rose-600"><%= budget.errors.full_messages_for(:amount_limit).first %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", budgets_path, class: "text-sm font-medium text-slate-600 hover:text-slate-800" %>
  </div>
<% end %>
