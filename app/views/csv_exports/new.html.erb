<div class="flex items-center justify-between mb-6">
  <h1 class="text-lg font-semibold text-slate-900">Export Transactions</h1>
</div>

<div class="bg-white rounded-lg border border-slate-200 p-4 sm:p-6">
  <p class="text-sm text-slate-500 mb-6">Select which transactions to include in the export. Leave filters blank to export all.</p>

  <%= form_with url: csv_exports_path, method: :post, data: { turbo: false } do |f| %>
    <div class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :start_date, "From date", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.date_field :start_date, value: params[:start_date], class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm h-11" %>
        </div>
        <div>
          <%= f.label :end_date, "To date", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.date_field :end_date, value: params[:end_date], class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm h-11" %>
        </div>
      </div>

      <div>
        <%= f.label :account_id, "Account", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :account_id, options_from_collection_for_select(@accounts, :id, :name), { include_blank: "All accounts" }, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm h-11" %>
      </div>

      <div>
        <%= f.label :category_id, "Category", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name), { include_blank: "All categories" }, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm h-11" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Download CSV", class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" %>
      </div>
    </div>
  <% end %>

  <p class="mt-4 text-xs text-slate-400">The exported file will include columns for date, account, kind, category, amount, and note.</p>
</div>
