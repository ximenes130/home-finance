<%= render "shared/page_header", title: "Categories", action_path: new_category_path, action_label: "New Category" %>

<% if @income_categories.any? || @expense_categories.any? %>
  <div class="space-y-6">
    <% if @income_categories.any? %>
      <div>
        <h2 class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-3">Income Categories</h2>
        <div class="bg-white rounded-lg border border-slate-200">
          <ul class="divide-y divide-slate-100">
            <% @income_categories.each do |category| %>
              <li class="flex items-center justify-between px-4 py-2.5">
                <div class="flex items-center gap-2">
                  <span class="inline-block h-2 w-2 rounded-full bg-emerald-500"></span>
                  <span class="text-sm font-medium text-slate-900"><%= category.name %></span>
                </div>
                <div class="flex items-center gap-2">
                  <%= link_to "Edit", edit_category_path(category), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
                  <% if category.deletable? %>
                    <%= button_to "Delete", category_path(category), method: :delete,
                        data: { turbo_confirm: "Delete '#{category.name}'? Its budgets will also be removed. This cannot be undone." },
                        class: "text-sm text-rose-600 hover:text-rose-700" %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <% if @expense_categories.any? %>
      <div>
        <h2 class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-3">Expense Categories</h2>
        <div class="bg-white rounded-lg border border-slate-200">
          <ul class="divide-y divide-slate-100">
            <% @expense_categories.each do |category| %>
              <li class="flex items-center justify-between px-4 py-2.5">
                <div class="flex items-center gap-2">
                  <span class="inline-block h-2 w-2 rounded-full bg-rose-500"></span>
                  <span class="text-sm font-medium text-slate-900"><%= category.name %></span>
                </div>
                <div class="flex items-center gap-2">
                  <%= link_to "Edit", edit_category_path(category), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
                  <% if category.deletable? %>
                    <%= button_to "Delete", category_path(category), method: :delete,
                        data: { turbo_confirm: "Delete '#{category.name}'? Its budgets will also be removed. This cannot be undone." },
                        class: "text-sm text-rose-600 hover:text-rose-700" %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-12">
    <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M6 6h.008v.008H6V6z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <h3 class="mt-2 text-sm font-semibold text-slate-900">No categories yet</h3>
    <p class="mt-1 text-sm text-slate-500">Create categories to classify your transactions.</p>
    <div class="mt-6">
      <%= link_to new_category_path,
          class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        New Category
      <% end %>
    </div>
  </div>
<% end %>
