<%= form_with(model: category, class: "space-y-6 max-w-lg") do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :name,
        placeholder: "e.g. Groceries",
        class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm #{category.errors[:name].any? ? 'border-rose-300 text-rose-900 focus:border-rose-500 focus:ring-rose-500' : ''}" %>
    <% if category.errors[:name].any? %>
      <p class="mt-1 text-sm text-rose-600"><%= category.errors.full_messages_for(:name).first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :kind, class: "block text-sm font-medium text-slate-700" %>
    <% if category.persisted? && category.transactions.any? %>
      <p class="mt-1 text-sm text-slate-900"><%= category.kind.capitalize %></p>
      <p class="mt-1 text-xs text-slate-500">Kind cannot be changed because this category has transactions.</p>
      <%= f.hidden_field :kind %>
    <% else %>
      <%= f.select :kind,
          options_for_select([["Income", "income"], ["Expense", "expense"]], category.kind),
          {},
          class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm #{category.errors[:kind].any? ? 'border-rose-300 text-rose-900 focus:border-rose-500 focus:ring-rose-500' : ''}" %>
    <% end %>
    <% if category.errors[:kind].any? %>
      <p class="mt-1 text-sm text-rose-600"><%= category.errors.full_messages_for(:kind).first %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", categories_path, class: "text-sm font-medium text-slate-600 hover:text-slate-800" %>
  </div>
<% end %>
