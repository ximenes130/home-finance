<%= render "shared/page_header", title: "Accounts", action_path: new_account_path, action_label: "New Account" %>

<% active_accounts = @accounts.select(&:active?) %>
<% inactive_accounts = @accounts.reject(&:active?) %>

<% if @accounts.any? %>
  <%# Desktop table %>
  <div class="hidden sm:block bg-white rounded-lg border border-slate-200">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Name</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Type</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Balance</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Status</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% active_accounts.each do |account| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3">
              <%= link_to account.name, account, class: "text-sm font-medium text-slate-900 hover:text-indigo-600" %>
            </td>
            <td class="px-4 py-3"><%= account_type_badge(account.account_type) %></td>
            <td class="px-4 py-3 text-sm font-semibold tabular-nums text-right <%= account.balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
              <%= format_currency(account.balance) %>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-700">Active</span>
            </td>
            <td class="px-4 py-3 text-right space-x-2">
              <%= link_to "Edit", edit_account_path(account), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
              <%= button_to "Deactivate", account_activation_path(account), method: :delete, class: "text-sm text-slate-600 hover:text-slate-800" %>
            </td>
          </tr>
        <% end %>

        <% if inactive_accounts.any? && active_accounts.any? %>
          <tr>
            <td colspan="5" class="px-4 py-1">
              <hr class="border-slate-300">
            </td>
          </tr>
        <% end %>

        <% inactive_accounts.each do |account| %>
          <tr class="hover:bg-slate-50 opacity-60">
            <td class="px-4 py-3">
              <%= link_to account.name, account, class: "text-sm font-medium text-slate-900 hover:text-indigo-600" %>
            </td>
            <td class="px-4 py-3"><%= account_type_badge(account.account_type) %></td>
            <td class="px-4 py-3 text-sm font-semibold tabular-nums text-right <%= account.balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
              <%= format_currency(account.balance) %>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-slate-100 text-slate-500">Inactive</span>
            </td>
            <td class="px-4 py-3 text-right space-x-2">
              <%= link_to "Edit", edit_account_path(account), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
              <%= button_to "Reactivate", account_activation_path(account), method: :post, class: "text-sm text-indigo-600 hover:text-indigo-700" %>
              <% if account.deletable? %>
                <%= button_to "Delete", account_path(account), method: :delete,
                    data: { turbo_confirm: "Delete #{account.name}? This cannot be undone." },
                    class: "text-sm text-rose-600 hover:text-rose-700" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Mobile cards %>
  <div class="sm:hidden space-y-3">
    <% active_accounts.each do |account| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4">
        <div class="flex items-center justify-between">
          <%= link_to account.name, account, class: "text-sm font-medium text-slate-900 hover:text-indigo-600" %>
          <span class="text-sm font-semibold tabular-nums <%= account.balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
            <%= format_currency(account.balance) %>
          </span>
        </div>
        <div class="mt-1 flex items-center gap-2">
          <%= account_type_badge(account.account_type) %>
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-700">Active</span>
        </div>
        <div class="mt-3 flex items-center gap-3">
          <%= link_to "Edit", edit_account_path(account), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
          <%= button_to "Deactivate", account_activation_path(account), method: :delete, class: "text-sm text-slate-600 hover:text-slate-800" %>
        </div>
      </div>
    <% end %>

    <% if inactive_accounts.any? && active_accounts.any? %>
      <hr class="border-slate-300">
    <% end %>

    <% inactive_accounts.each do |account| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4 opacity-60">
        <div class="flex items-center justify-between">
          <%= link_to account.name, account, class: "text-sm font-medium text-slate-900 hover:text-indigo-600" %>
          <span class="text-sm font-semibold tabular-nums <%= account.balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
            <%= format_currency(account.balance) %>
          </span>
        </div>
        <div class="mt-1 flex items-center gap-2">
          <%= account_type_badge(account.account_type) %>
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-slate-100 text-slate-500">Inactive</span>
        </div>
        <div class="mt-3 flex items-center gap-3">
          <%= link_to "Edit", edit_account_path(account), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
          <%= button_to "Reactivate", account_activation_path(account), method: :post, class: "text-sm text-indigo-600 hover:text-indigo-700" %>
          <% if account.deletable? %>
            <%= button_to "Delete", account_path(account), method: :delete,
                data: { turbo_confirm: "Delete #{account.name}? This cannot be undone." },
                class: "text-sm text-rose-600 hover:text-rose-700" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-12">
    <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <h3 class="mt-2 text-sm font-semibold text-slate-900">No accounts yet</h3>
    <p class="mt-1 text-sm text-slate-500">Create your first account to start tracking finances.</p>
    <div class="mt-6">
      <%= link_to new_account_path,
          class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        New Account
      <% end %>
    </div>
  </div>
<% end %>
