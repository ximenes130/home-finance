<div class="mb-6">
  <%= link_to "← Back to Accounts", accounts_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %>
</div>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-lg font-semibold text-slate-900"><%= @account.name %></h1>
    <div class="mt-1 flex items-center gap-2">
      <%= account_type_badge(@account.account_type) %>
      <% if @account.active? %>
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-700">Active</span>
      <% else %>
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-slate-100 text-slate-500">Inactive</span>
      <% end %>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_account_path(@account), class: "inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" %>
    <% if @account.active? %>
      <%= button_to "Deactivate", account_activation_path(@account), method: :delete,
          class: "inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-700 border border-slate-300 shadow-sm hover:bg-slate-50" %>
    <% else %>
      <%= button_to "Reactivate", account_activation_path(@account), method: :post,
          class: "inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-indigo-600 border border-slate-300 shadow-sm hover:bg-slate-50" %>
    <% end %>
    <% if @account.deletable? %>
      <%= button_to "Delete", account_path(@account), method: :delete,
          data: { turbo_confirm: "Delete #{@account.name}? This cannot be undone." },
          class: "inline-flex items-center gap-2 rounded-md bg-rose-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-rose-700" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Balance</p>
    <p class="mt-1 text-2xl font-semibold tabular-nums <%= @account.balance.negative? ? 'text-rose-600' : 'text-slate-900' %>">
      <%= format_currency(@account.balance) %>
    </p>
  </div>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Income This Month</p>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-emerald-600">
      <%= format_currency(@account.transactions.where(kind: "income")
            .where(transaction_date: Date.current.all_month).sum(:amount)) %>
    </p>
  </div>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Expenses This Month</p>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-rose-600">
      <%= format_currency(@account.transactions.where(kind: "expense")
            .where(transaction_date: Date.current.all_month).sum(:amount)) %>
    </p>
  </div>
</div>

<h2 class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-4">Recent Transactions</h2>

<% if @recent_transactions.any? %>
  <div class="bg-white rounded-lg border border-slate-200">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Date</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Kind</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Category</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wide">Note</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wide">Amount</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @recent_transactions.each do |transaction| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 text-sm text-slate-500 whitespace-nowrap">
              <%= transaction.transaction_date.strftime("%b %d, %Y") %>
            </td>
            <td class="px-4 py-3">
              <% badge_classes = case transaction.kind
                 when "income" then "bg-emerald-50 text-emerald-700"
                 when "expense" then "bg-rose-50 text-rose-700"
                 else "bg-blue-50 text-blue-700"
                 end %>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= badge_classes %>">
                <%= transaction.kind.capitalize %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-slate-500"><%= transaction.category&.name %></td>
            <td class="px-4 py-3 text-sm text-slate-500 truncate max-w-xs"><%= transaction.note %></td>
            <td class="px-4 py-3 text-sm font-medium tabular-nums text-right
                <% if transaction.kind == 'income' %>text-emerald-600<% elsif transaction.kind == 'expense' %>text-rose-600<% else %>text-blue-600<% end %>">
              <% if transaction.kind == "income" %>+<% elsif transaction.kind == "expense" %>-<% end %><%= format_currency(transaction.amount) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-8 bg-white rounded-lg border border-slate-200">
    <p class="text-sm text-slate-500">No transactions yet for this account.</p>
  </div>
<% end %>
